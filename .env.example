# Choose your provider and model
GROQ_API_KEY=your_key_here
OPENROUTER_API_KEY=your_key_here

# Provider Configuration (Options: "groq", "openrouter", "ollama", "lmstudio")
AI_PROVIDER=groq

# Model Choices
# Groq:       "meta-llama/llama-4-scout-17b-16e-instruct"
# OpenRouter: "meta-llama/llama-4-scout-17b-16e-instruct"
# Ollama:     "llama4" (or any model you've pulled)
# LM Studio:  Use the model identifier shown in LM Studio
AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional: Override default local URLs
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
AI_MODEL=llama-3.1-70b-versatile
